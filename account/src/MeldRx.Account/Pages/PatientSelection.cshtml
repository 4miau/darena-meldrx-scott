@page
@model MeldRx.Account.Pages.PatientSelectionModel
@{
    Layout = "_Layout";
}

<style>
    @@media (max-width:767px) {
        .header-menu.menu.d-flex {
            display: none !important;
        }
    }
</style>
<link href="./dist/css/patientSearch.css" rel="stylesheet" />
<div class="patient-search-page">
    <div class="white-box">
        <h3>Search Patients</h3>
        <div class="patient-search-form">
            <input type="text" hidden value="@Model.FhirUrl" id="fhir-api-url" asp-for="FhirUrl" />
            <input type="text" id="search-text" class="form-control" onkeyup="onPatientSearch(this.value,false)" placeholder="Type to search.." asp-for="SearchText" />
        </div>
        <h4 id="error-message" class="d-none"></h4>
        <h4 id="no-record-found" class="error d-none"></h4>
        <div id="patients-list"></div>
    </div>
</div>
